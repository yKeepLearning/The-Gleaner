<!-- collection.wxml -->
<view class="page-collection">
  <!-- 导航栏 -->
  <navigation-bar title="可能性博物馆" back="{{false}}" color="white" background="#0a0a1a"></navigation-bar>
  
  <!-- 主内容区 -->
  <view class="main-content">
    <!-- 卡片网格 -->
    <view wx:if="{{collectionList.length > 0}}" class="card-grid">
      <view 
        wx:for="{{collectionList}}" 
        wx:key="id"
        class="card-item"
      >
        <card 
          cardData="{{item}}" 
          mode="collection"
          bind:tap="onTapCard"
        ></card>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view wx:else class="empty-state">
      <text class="empty-icon">📦</text>
      <text class="empty-text">还没有收藏任何赃物</text>
      <text class="empty-hint">每天来这里看看它带回了什么</text>
    </view>
  </view>
  
  <!-- 详情弹窗 -->
  <view wx:if="{{showDetail}}" class="detail-modal" bind:tap="onCloseDetail">
    <view class="modal-content" catch:tap="preventBubble">
      <!-- 关闭按钮 -->
      <view class="close-btn" bind:tap="onCloseDetail">
        <text class="close-icon">✕</text>
      </view>
      
      <!-- 卡片详情 -->
      <view class="detail-card">
        <view class="detail-header">
          <text class="detail-type">{{currentCard.type === 'A' ? '电子排泄物' : currentCard.type === 'B' ? '平行世界切片' : '稀有掉落'}}</text>
          <text class="detail-date">{{currentCard.date}}</text>
        </view>
        
        <view class="detail-content">
          <text class="detail-text">{{currentCard.content}}</text>
        </view>
      </view>
      
      <!-- 交易对话记录 -->
      <view wx:if="{{currentDialogue}}" class="dialogue-section">
        <text class="dialogue-title">交易对话记录</text>
        
        <view class="dialogue-item">
          <text class="dialogue-speaker">它说：</text>
          <text class="dialogue-content">{{currentDialogue.it_said}}</text>
        </view>
        
        <view class="dialogue-item">
          <text class="dialogue-speaker">你说：</text>
          <text class="dialogue-content">{{currentDialogue.you_said}}</text>
        </view>
      </view>
    </view>
  </view>
</view>