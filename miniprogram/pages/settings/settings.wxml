<!-- settings.wxml -->
<view class="page-settings">
  <!-- 导航栏 -->
  <navigation-bar title="设置" back="{{false}}" color="white" background="#0a0a1a"></navigation-bar>
  
  <!-- 主内容区 -->
  <view class="main-content">
    <!-- 设置列表 -->
    <view class="settings-list">
      <view 
        wx:for="{{settingsList}}" 
        wx:key="id"
        class="setting-item {{item.danger ? 'danger' : ''}}"
        data-id="{{item.id}}"
        data-type="{{item.type}}"
        bind:tap="{{item.type === 'navigate' ? 'onTapSetting' : 'onToggleNotification'}}"
      >
        <!-- 左侧图标和标题 -->
        <view class="setting-left">
          <text class="setting-icon">{{item.icon}}</text>
          <text class="setting-title">{{item.title}}</text>
        </view>
        
        <!-- 右侧控件 -->
        <view class="setting-right">
          <!-- 开关控件 -->
          <switch 
            wx:if="{{item.type === 'switch'}}"
            checked="{{item.value}}"
            color="#00f0ff"
            class="setting-switch"
          />
          
          <!-- 箭头 -->
          <text wx:else class="setting-arrow">›</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 关于弹窗 -->
  <view wx:if="{{showAbout}}" class="about-modal" bind:tap="onCloseAbout">
    <view class="modal-content" catch:tap="preventBubble">
      <!-- 关闭按钮 -->
      <view class="close-btn" bind:tap="onCloseAbout">
        <text class="close-icon">✕</text>
      </view>
      
      <!-- 关于内容 -->
      <view class="about-content">
        <text class="about-name">{{aboutInfo.name}}</text>
        <text class="about-slogan">{{aboutInfo.slogan}}</text>
        <text class="about-version">{{aboutInfo.version}}</text>
        
        <view class="about-divider"></view>
        
        <text class="about-description">{{aboutInfo.description}}</text>
      </view>
    </view>
  </view>
</view>